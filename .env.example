# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_URI=mongodb+srv://your-user:your-password@your-cluster.mongodb.net/

# MongoDB database name (defaults to "marriage" if not set)
MONGODB_DB=marriage

# Admin dashboard access
OWNER_ACCESS_CODE=change-this-owner-code
SITE_ACCESS_SECRET=change-this-random-secret
